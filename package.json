    "decision-center:unified-env-check": "bash scripts/harness-decision-center-unified-env-check.sh",
    "decision-center:unified-qa": "bash scripts/harness-decision-center-unified-qa.sh",
    "decision-center:resolutions-probe": "bash scripts/harness-decision-resolutions.sh",
    "check:semantic-colors": "bash scripts/check-semantic-colors.sh",
    "migrate:semantic-colors": "node scripts/migrate-semantic-colors.mjs",
    "migrate:product-surface-colors": "node scripts/migrate-product-surface-colors.mjs",
    "migrate:decision-problems-warn-colors": "node scripts/migrate-decision-problems-warn-colors.mjs"
